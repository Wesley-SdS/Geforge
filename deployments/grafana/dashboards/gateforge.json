          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(gateforge_http_requests_total{status_code=~\"5..\"}[$__rate_interval])) / sum(rate(gateforge_http_requests_total[$__rate_interval])) * 100",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
